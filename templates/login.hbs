<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CHAT BOT</title>
    <link rel="stylesheet" href="/login.CSS">
</head>

<body>
    <div class="login-box">
        <div class="logo">
            <img src="/logo-png.png" alt="Chat Bot Logo">
            <div class="logo-text">Bard Powered Chatbot</div>
        </div>
        <form action="/login" method="post">
            <div class="login-header">
                <header>Login</header>
            </div>

            <div class="input-box">
                <input type="text" name="name" placeholder="Name" class="input-field">
            </div>
            <div class="input-box">
                <input type="text" name="password" placeholder="Password" class="input-field">
            </div>

            <div class="input-submit">
                <button class="submit-btn" id="submit"></button>
                <label for="submit">Log In</label>
            </div>

            <div class="sign-up-link">
                <p>Don't have account?<a href="/signup">Sign Up</a></p>
            </div>

        </form>

    </div>
</body>

</html>