<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CHAT BOT</title>
    <link rel="stylesheet" href="/signup.css">
</head>
<body>
     <div class="login-box">
          <div class="logo">
            <img src="/logo-png.png" alt="Chat Bot Logo" >
            <div class="logo-text">Bard Powered Chatbot</div>
        </div>
        <form action="/signup" method="post">  
            <div class="login-header">
                <header>Sign In</header>
            </div>

            <div class="input-box">
                <input type="text" name="name" placeholder="Name" class="input-field">
            </div>
            <div class="input-box">
                <input type="text" name="password" placeholder="Password" class="input-field">
            </div>

            <div class="input-submit">
                <button class="submit-btn" id="submit"></button>
                <label for="submit">Sign In</label>
            </div>


        </form>
   
    </div>
</body>
</html>